# Optional local collector settings. Replace paths with files on your machine.
RSS_AI_ENDPOINT=http://localhost:3000
WECHAT_EXPORTER=./scripts/wechat-exporter-browser.py
WECHAT_WIZARD=/absolute/path/to/wechat_wizard.py
WECHAT_DOWNLOADER=/absolute/path/to/wechat_downloader.py
MOORE_WECHAT_EXPORTER_SCRIPT=/absolute/path/to/wechat_exporter.py

# Set this in the hosted runtime when remote imports are enabled.
IMPORT_TOKEN=replace-with-a-random-secret
